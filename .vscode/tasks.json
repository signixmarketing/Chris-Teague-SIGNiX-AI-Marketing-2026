{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "${command:python.interpreterPath} -m pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PIP_DISABLE_PIP_VERSION_CHECK": "1"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Restore distribution",
      "type": "shell",
      "command": "${command:python.interpreterPath} scripts/restore_distribution.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "First-time setup (install + restore)",
      "type": "shell",
      "command": "echo 'Run completed.'",
      "dependsOrder": "sequence",
      "dependsOn": ["Install dependencies", "Restore distribution"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
