              "conditions": {
                "options": {
                  "version": 2,
                  "leftValue": "",
                  "caseSensitive": true,
                  "typeValidation": "strict"
                },
                "combinator": "and",
                "conditions": [
                  {
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "leftValue": "={{ $json.route }}",
                    "rightValue": "low"
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "low_volume"
            },
            {
              "conditions": {
                "options": {
                  "version": 2,
                  "leftValue": "",
