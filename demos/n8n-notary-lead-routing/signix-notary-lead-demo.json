    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const raw = $input.first().json;\nconst body = raw.body && typeof raw.body === 'object' && !Array.isArray(raw.body)\n  ? raw.body\n  : raw;\n\nconst product = String(body.product_interest || '').toLowerCase().trim();\nconst band = String(body.monthly_notary_volume || '').trim();\n\nconst isNotary = product === 'enotary';\n\nlet route = 'default';\nif (isNotary && band === '0-5') {\n  route = 'low';\n} else if (isNotary && band === '30+') {\n  route = 'high';\n}\n\nreturn [\n  {\n    json: {\n      first_name: body.first_name || '',\n      last_name: body.last_name || '',\n      email: body.email || '',\n      phone: body.phone || '',\n      company: body.company || '',\n      job_title: body.job_title || '',\n      product_interest: body.product_interest || '',\n      monthly_notary_volume: body.monthly_notary_volume || '',\n      route,\n      is_notary: isNotary,\n    },\n  },\n];"
      },
      "id": "a1000001-0000-4000-8000-000000000002",
      "name": "Normalize and score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
